# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=spotly_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=spotly_db

# ─── Server (passed through to container via env_file) ────────────────────────
PORT=3000
NODE_ENV=production
DATABASE_URL="postgresql://spotly_user:change_this_password@postgres:5432/spotly_db"
REDIS_HOST=redis
REDIS_PORT=6379
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
CLIENT_ORIGIN=http://localhost:8081
