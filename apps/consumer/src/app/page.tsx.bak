"use client"

import { useEffect, useState } from "react"
import { useAuthStore } from "@/store/auth.store"
import { useRouter } from "next/navigation"
import { AuthModal, Ic, Orb } from "@spotly/ui"
import { MERCHANTS } from "@spotly/ui/src/data/mock"

const s = {
  glass: { background: 'rgba(255,255,255,.035)', backdropFilter: 'blur(24px)', WebkitBackdropFilter: 'blur(24px)', border: '1px solid var(--bdr)' },
  glassStrong: { background: 'rgba(255,255,255,.07)', backdropFilter: 'blur(32px)', WebkitBackdropFilter: 'blur(32px)', border: '1px solid var(--bdr2)' },
  card: { background: 'var(--s1)', border: '1px solid var(--bdr)', borderRadius: 18, padding: 22, transition: 'all .3s cubic-bezier(.25,.46,.45,.94)' },
  gradC: { background: 'linear-gradient(135deg,#f5c418,#ff6316)' },
  gradCText: { background: 'linear-gradient(135deg,#f5c418,#ff6316)', WebkitBackgroundClip: 'text', WebkitTextFillColor: 'transparent', backgroundClip: 'text' },
  btnC: { display: 'inline-flex', alignItems: 'center', justifyContent: 'center', gap: 8, padding: '13px 26px', borderRadius: 12, background: 'linear-gradient(135deg,#f5c418,#ff6316)', color: '#000', fontWeight: 700, fontSize: 14, border: 'none', cursor: 'pointer', transition: 'all .22s' },
  btnGhost: { display: 'inline-flex', alignItems: 'center', justifyContent: 'center', gap: 8, padding: '11px 18px', borderRadius: 11, background: 'rgba(255,255,255,.05)', color: 'rgba(255,255,255,.7)', fontWeight: 600, fontSize: 14, border: '1px solid var(--bdr2)', cursor: 'pointer', transition: 'all .2s' },
  badge: (c: string) => ({
    display: 'inline-flex', alignItems: 'center', gap: 4, padding: '3px 9px', borderRadius: 999, fontSize: 11, fontWeight: 700, letterSpacing: .3,
    ...(c === 'yellow' && { background: 'rgba(245,196,24,.12)', color: '#f5c418', border: '1px solid rgba(245,196,24,.22)' }),
    ...(c === 'green' && { background: 'rgba(31,217,124,.12)', color: '#1fd97c', border: '1px solid rgba(31,217,124,.22)' }),
  })
}

export default function LandingPage() {
  const { user, signInWithEmail, signUpWithEmail, loading } = useAuthStore()
  const router = useRouter()
  const [isAuthModalOpen, setIsAuthModalOpen] = useState(false)

  const cats = ['☕ Coffee', '💊 Health', '🥐 Bakery', '🥬 Grocery', '✂️ Salon', '🏦 Finance', '🍽️ Dining', '💅 Beauty'];
  const stats = [
    { n: 50000, s: 'K+', l: 'Tokens daily' },
    { n: 4.2, s: 'min', l: 'Avg wait saved' },
    { n: 98, s: '%', l: 'Notification accuracy' },
    { n: 200, s: '+', l: 'Partner merchants' }
  ];

  useEffect(() => {
    if (!loading && user) {
      router.push("/home")
    }
  }, [loading, user, router])

  if (loading) return null

  return (
    <div style={{ minHeight: '100vh', background: 'var(--bg)', overflow: 'hidden auto', color: 'white' }}>
      
      {/* NAV */}
      <nav style={{ ...s.glass, padding: '0 44px', height: 70, display: 'flex', alignItems: 'center', justifyContent: 'space-between', position: 'sticky', top: 0, zIndex: 100 }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
          <div style={{ width: 34, height: 34, borderRadius: 10, ...s.gradC, display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: 16 }}>⏱</div>
          <span style={{ fontSize: 22, fontWeight: 900, letterSpacing: -1, fontFamily: 'var(--font-sans)' }}>spotly</span>
        </div>
        <div style={{ display: 'flex', gap: 8 }}>
          <button style={{ ...s.btnGhost, padding: '9px 20px', fontSize: 13 }} onClick={() => router.push('http://localhost:3001')}>Merchant Portal</button>
        </div>
      </nav>

      {/* HERO */}
      <section style={{ minHeight: '92vh', display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', position: 'relative', padding: '80px 24px 60px', textAlign: 'center', overflow: 'hidden' }}>
        <Orb x="-18%" y="-14%" size="62%" color="rgba(245,196,24,.22)" anim="orb1 13s ease-in-out infinite" />
        <Orb x="58%" y="15%" size="56%" color="rgba(255,99,22,.18)" anim="orb2 17s ease-in-out infinite" />
        <Orb x="18%" y="62%" size="42%" color="rgba(31,217,124,.1)" anim="orb1 10s ease-in-out infinite 3s" />

        <div style={{ position: 'absolute', inset: 0, backgroundImage: `url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E")`, pointerEvents: 'none', opacity: 0.6 }} />

        <div className="au" style={{ display: 'inline-flex', alignItems: 'center', gap: 8, padding: '6px 16px', borderRadius: 999, ...s.glass, marginBottom: 28, fontSize: 11, fontWeight: 700, color: '#f5c418', textTransform: 'uppercase', letterSpacing: 1.5 }}>
          <div style={{ width: 6, height: 6, borderRadius: '50%', background: '#1fd97c', animation: 'pulse 2s infinite' }} />
          Live in Bengaluru — 200+ merchants
        </div>

        <h1 className="au" style={{ fontSize: 'clamp(52px,7.5vw,104px)', fontWeight: 900, letterSpacing: '-4px', lineHeight: 0.88, fontFamily: 'var(--font-sans)', marginBottom: 28, maxWidth: 980 }}>
          Skip the line.<br /><span style={s.gradCText as React.CSSProperties}>Live your time.</span>
        </h1>
        <p className="au" style={{ fontSize: 'clamp(16px,2vw,20px)', color: 'var(--t2)', maxWidth: 520, lineHeight: 1.7, marginBottom: 52 }}>
          Join queues at cafés, clinics & shops from anywhere. Get real-time alerts. Arrive only when it's your turn.
        </p>

        <div className="au" style={{ display: 'flex', gap: 12, flexWrap: 'wrap', justifyContent: 'center', marginBottom: 72 }}>
          <button style={{ ...s.btnC, padding: '16px 40px', fontSize: 16, borderRadius: 14, gap: 10 }} onClick={() => setIsAuthModalOpen(true)}
            onMouseEnter={e => { e.currentTarget.style.transform = 'translateY(-3px)'; e.currentTarget.style.boxShadow = '0 28px 60px rgba(245,196,24,.45)' }}
            onMouseLeave={e => { e.currentTarget.style.transform = ''; e.currentTarget.style.boxShadow = '' }}>
            Find Nearby <Ic.Arrow />
          </button>
          <button style={{ ...s.btnGhost, padding: '16px 36px', fontSize: 16, borderRadius: 14 }} onClick={() => router.push('http://localhost:3001')}
            onMouseEnter={e => e.currentTarget.style.borderColor = 'rgba(255,255,255,.3)'}
            onMouseLeave={e => e.currentTarget.style.borderColor = 'var(--bdr2)'}>
            For Merchants <Ic.ChevR />
          </button>
        </div>

        <div style={{ display: 'flex', gap: 14, flexWrap: 'wrap', justifyContent: 'center', maxWidth: 720, zIndex: 1, position: 'relative' }}>
          {MERCHANTS.slice(0, 4).map((m, i) => (
            <div key={m.id} className="af" style={{ ...s.glass, borderRadius: 18, padding: '14px 18px', display: 'flex', alignItems: 'center', gap: 12, width: 200, animationDelay: `${i * 1.4}s`, cursor: 'pointer', transition: 'all .3s' }}
              onMouseEnter={e => { e.currentTarget.style.transform = 'translateY(-8px) scale(1.04)'; e.currentTarget.style.borderColor = 'rgba(245,196,24,.35)' }}
              onMouseLeave={e => { e.currentTarget.style.transform = ''; e.currentTarget.style.borderColor = 'var(--bdr)' }}>
              <div style={{ fontSize: 30 }}>{m.emoji}</div>
              <div style={{ textAlign: 'left' }}>
                <div style={{ fontWeight: 700, fontSize: 13, marginBottom: 3 }}>{m.name}</div>
                <div style={{ display: 'flex', alignItems: 'center', gap: 6 }}>
                  <span style={{ ...s.badge('yellow'), fontSize: 10, padding: '2px 7px' }}>⏱ {m.waitStr}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      {/* TICKER */}
      <div style={{ ...s.glass, padding: '16px 0', overflow: 'hidden' }}>
        <div style={{ display: 'inline-flex', animation: 'ticker 24s linear infinite', gap: 56, whiteSpace: 'nowrap' }}>
          {[...cats, ...cats].map((c, i) => (
            <span key={i} style={{ fontSize: 13, fontWeight: 600, color: 'var(--t3)', display: 'flex', alignItems: 'center', gap: 8 }}>
              {c}<span style={{ color: 'rgba(255,255,255,.12)' }}>◆</span>
            </span>
          ))}
        </div>
      </div>

      {/* STATS */}
      <section style={{ ...s.glassStrong, borderRadius: 24, maxWidth: 920, margin: '80px auto', padding: '56px 48px' }}>
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(4,1fr)', gap: 40, textAlign: 'center' }}>
          {stats.map((st, i) => (
            <div key={i}>
              <div style={{ fontFamily: 'var(--font-sans)', fontSize: 52, fontWeight: 900, ...s.gradCText as React.CSSProperties, marginBottom: 6, lineHeight: 1 }}>
                {st.n === 4.2 ? '4.2' : `${st.n / 1000 >= 1 ? st.n / 1000 : st.n}`}{st.s}
              </div>
              <div style={{ color: 'var(--t3)', fontSize: 13, fontWeight: 500 }}>{st.l}</div>
            </div>
          ))}
        </div>
      </section>

      {/* FEATURES */}
      <section style={{ padding: '40px 44px 100px', maxWidth: 1100, margin: '0 auto' }}>
        <div style={{ textAlign: 'center', marginBottom: 56 }}>
          <div style={{ ...s.badge('green'), marginBottom: 14, padding: '5px 14px', display: 'inline-flex' }}>How it works</div>
          <h2 style={{ fontFamily: 'var(--font-sans)', fontSize: 52, fontWeight: 900, letterSpacing: -2 }}>Queue smarter,<br /><span style={s.gradCText as React.CSSProperties}>not harder</span></h2>
        </div>
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit,minmax(290px,1fr))', gap: 20 }}>
          {[
            { icon: <Ic.Search />, color: '#f5c418', title: 'Discover nearby', desc: 'Browse merchants with live queue counts. Filter by wait time, category, or rating.' },
            { icon: <Ic.Zap />, color: '#1fd97c', title: 'Join instantly', desc: 'One tap to join any queue remotely. No paper tokens. Your phone is your ticket.' },
            { icon: <Ic.Bell />, color: '#a78bfa', title: 'Arrive on time', desc: 'Get alerts when you're next. Real-time position updates so you never miss your turn.' },
          ].map((f, i) => (
            <div key={i} style={{ ...s.card, padding: 34, cursor: 'default' }}
              onMouseEnter={e => { e.currentTarget.style.transform = 'translateY(-8px)'; e.currentTarget.style.borderColor = f.color + '44'; e.currentTarget.style.boxShadow = `0 32px 80px rgba(0,0,0,.5),0 0 40px ${f.color}18` }}
              onMouseLeave={e => { e.currentTarget.style.transform = ''; e.currentTarget.style.borderColor = 'var(--bdr)'; e.currentTarget.style.boxShadow = '' }}>
              <div style={{ width: 52, height: 52, borderRadius: 14, background: `${f.color}18`, border: `1px solid ${f.color}30`, display: 'flex', alignItems: 'center', justifyContent: 'center', color: f.color, marginBottom: 22 }}>
                {f.icon}
              </div>
              <h3 style={{ fontFamily: 'var(--font-sans)', fontSize: 21, fontWeight: 800, marginBottom: 10 }}>{f.title}</h3>
              <p style={{ color: 'var(--t2)', lineHeight: 1.7, fontSize: 15 }}>{f.desc}</p>
            </div>
          ))}
        </div>
      </section>

      {/* FOOTER */}
      <footer style={{ padding: '36px 44px', borderTop: '1px solid var(--bdr)', display: 'flex', alignItems: 'center', justifyContent: 'space-between', color: 'var(--t3)', fontSize: 13, flexWrap: 'wrap', gap: 12 }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
          <div style={{ width: 26, height: 26, borderRadius: 8, ...s.gradC, display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: 13 }}>⏱</div>
          <span style={{ fontFamily: 'var(--font-sans)', fontWeight: 800, color: 'var(--t2)' }}>spotly</span>
        </div>
        <p>© {new Date().getFullYear()} Spotly Technologies · Bengaluru, India</p>
      </footer>

      <AuthModal
        isOpen={isAuthModalOpen}
        onClose={() => setIsAuthModalOpen(false)}
        onAuth={async (email, password, isSignUp) => {
          if (isSignUp) {
            await signUpWithEmail(email, password);
          } else {
            await signInWithEmail(email, password);
          }
        }}
        title="Welcome to Spotly"
        variant="consumer"
      />
    </div>
  )
}
