generator client {
  provider = "prisma-client-js"
  engineType = "library"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}




model User {
  id              String   @id @default(uuid())
  email           String?  @unique
  phone           String?  @unique
  isPhoneVerified Boolean  @default(false)
  name            String?
  location        String?
  role            Role     @default(CONSUMER)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  merchant  Merchant?
  queues    QueueEntry[]
  reviews   Review[]
}


model Merchant {
  id          String   @id @default(uuid())
  ownerId     String   @unique
  user        User     @relation(fields: [ownerId], references: [id])
  spotId      String?  @unique // User-facing ID (e.g., SPOT-1234)
  name        String
  category    String
  description String?
  phone       String?
  contactEmail String?
  website     String?
  address     String?
  foundingYear Int?
  logoUrl     String?
  gstNumber   String?
  lat         Float?
  lng         Float?
  verified    Boolean  @default(false)
  
  outlets     Outlet[]
}


model Outlet {
  id          String   @id @default(uuid())
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id])
  name        String
  address     String
  lat         Float?
  lng         Float?
  isActive    Boolean  @default(true)
  openTime    String   @default("09:00")
  closeTime   String   @default("21:00")
  
  queues      QueueEntry[]
  menuCategories MenuCategory[]
}

model MenuCategory {
  id        String   @id @default(uuid())
  outletId  String
  outlet    Outlet   @relation(fields: [outletId], references: [id])
  name      String
  order     Int      @default(0)
  items     MenuItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuItem {
  id          String   @id @default(uuid())
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id])
  name        String
  description String?
  price       Float
  image       String?
  isAvailable Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model QueueEntry {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  outletId  String
  outlet    Outlet   @relation(fields: [outletId], references: [id])
  tokenNumber Int
  status    QueueStatus @default(WAITING) // WAITING, CALLED, SERVED, CANCELLED
  createdAt DateTime @default(now())
}

model Review {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  outletId    String
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())
}

enum Role {
  CONSUMER
  MERCHANT
  ADMIN
}

enum QueueStatus {
  PENDING_ACCEPTANCE
  WAITING
  CALLED
  SERVED
  CANCELLED
}
