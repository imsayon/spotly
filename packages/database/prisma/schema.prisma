generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String       @id @default(uuid())
  phone           String?      @unique
  name            String?
  role            Role         @default(CONSUMER)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  email           String?      @unique
  secondaryPhone  String?
  isPhoneVerified Boolean      @default(false)
  location        String?
  lat             Float?
  lng             Float?
  Favorite        Favorite[]
  queues          QueueEntry[]
  reviews         Review[]
}

model Merchant {
  id           String   @id @default(uuid())
  ownerId      String   @unique
  name         String
  category     String
  description  String?
  verified     Boolean  @default(false)
  contactEmail String?
  logoUrl      String?
  phone        String?
  address      String?
  foundingYear Int?
  gstNumber    String?
  website      String?
  lat          Float?
  lng          Float?
  spotId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  outlets      Outlet[]
}

model Outlet {
  id             String         @id @default(uuid())
  merchantId     String
  name           String
  address        String
  lat            Float?
  lng            Float?
  isActive       Boolean        @default(true)
  openTime       String?        @default("09:00")
  closeTime      String?        @default("21:00")
  createdAt      DateTime       @default(now())
  favorites      Favorite[]
  menuCategories MenuCategory[]
  merchant       Merchant       @relation(fields: [merchantId], references: [id])
  queues         QueueEntry[]
  dailyCounters  OutletDailyCounter[]
}

model MenuCategory {
  id        String     @id @default(uuid())
  outletId  String
  name      String
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  outlet    Outlet     @relation(fields: [outletId], references: [id])
  items     MenuItem[]
}

model MenuItem {
  id          String       @id @default(uuid())
  categoryId  String
  name        String
  description String?
  price       Float
  image       String?
  isAvailable Boolean      @default(true)
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  category    MenuCategory @relation(fields: [categoryId], references: [id])
}

model QueueEntry {
  id          String      @id @default(uuid())
  userId      String
  outletId    String
  status      QueueStatus @default(WAITING)
  createdAt   DateTime    @default(now())
  tokenNumber Int

  outlet      Outlet      @relation(fields: [outletId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  outletId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  
  @@unique([userId, outletId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Favorite {
  id        String   @id @default(uuid())
  userId    String
  outletId  String
  createdAt DateTime @default(now())
  outlet    Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, outletId])
}

enum Role {
  CONSUMER
  MERCHANT
  ADMIN
}

enum QueueStatus {
  WAITING
  CALLED
  SERVED
  MISSED
  CANCELLED
  PENDING_ACCEPTANCE
}

model OutletDailyCounter {
  outletId String
  date     DateTime @db.Date
  counter  Int      @default(0)
  outlet   Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@id([outletId, date])
}
