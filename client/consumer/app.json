{
  "expo": {
    "name": "Spotly",
    "slug": "spotly-consumer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "spotly",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#6366f1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.spotly.consumer"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366f1"
      },
      "package": "com.spotly.consumer"
    },
    "plugins": ["expo-router", "expo-location"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
