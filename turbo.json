{
	"$schema": "https://turbo.build/schema.json",
	"globalEnv": [
		"NODE_ENV",
		"PORT",
		"DATABASE_URL",
		"NEXT_PUBLIC_API_URL",
		"NEXT_PUBLIC_WS_URL",
		"NEXT_PUBLIC_SUPABASE_URL",
		"NEXT_PUBLIC_SUPABASE_ANON_KEY",
		"NEXT_PUBLIC_MERCHANT_URL"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", "dist/**", "!.next/cache/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"outputs": []
		},
		"type-check": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"clean": {
			"cache": false
		}
	}
}
